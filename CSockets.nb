Cell[BoxData[
 RowBox[{
  RowBox[{"sourceToLibraryFunction", "[", "source_String", "]"}], " ", ":=", 
  " ", "\n", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\n", "\t", 
     RowBox[{
     "name", ",", " ", "args", ",", " ", "resultType", ",", " ", "holdArgs", ",",
       " ", "argTypes"}], "\n", "}"}], ",", " ", "\n", "\t", 
    RowBox[{
     RowBox[{"name", " ", "=", " ", 
      RowBox[{"First", " ", "@", " ", 
       RowBox[{"StringCases", "[", 
        RowBox[{"source", ",", " ", "\n", "\t\t", 
         RowBox[{
          RowBox[{"Shortest", "[", 
           RowBox[{
           "StartOfString", " ", "~~", " ", "\"\<DLLEXPORT int \>\"", " ", "~~",
             " ", 
            RowBox[{"$name", ":", " ", 
             RowBox[{"(", 
              RowBox[{"LetterCharacter", ".."}], ")"}]}], " ", "~~", 
            " ", "\"\<(WolframLibrary\>\""}], "]"}], " ", ":>", " ", 
          "$name"}]}], "\n", "\t", "]"}]}]}], ";", " ", "\n", "\t", "\n", 
     "\t", 
     RowBox[{"args", " ", "=", " ", 
      RowBox[{"StringCases", "[", 
       RowBox[{"source", ",", " ", "\n", "\t\t", 
        RowBox[{
         RowBox[{"Shortest", "[", 
          RowBox[{
          "StartOfLine", " ", "~~", " ", "__", " ", "~~", " ", "\"\< \>\"", 
           " ", "~~", " ", 
           RowBox[{"$argName", ":", " ", 
            RowBox[{"(", 
             RowBox[{"LetterCharacter", ".."}], ")"}]}], " ", "~~", 
           " ", "\"\< = \>\"", " ", "~~", " ", "__", " ", "~~", 
           " ", "\"\<MArgument_get\>\"", " ", "~~", " ", "$argType__", " ", "~~",
            " ", "\"\<(Args[\>\"", " ", "~~", " ", 
           RowBox[{"$argNum", ":", " ", "NumberString"}], " ", "~~", 
           " ", "\"\<]\>\""}], "]"}], " ", ":>", " ", "\n", "\t\t\t", 
         RowBox[{"{", 
          RowBox[{"$argType", ",", " ", "$argName", ",", " ", 
           RowBox[{"ToExpression", "[", "$argNum", "]"}]}], "}"}]}]}], "\n", 
       "\t", "]"}]}], ";", "\n", "\t", "\n", "\t", 
     RowBox[{"resultType", " ", "=", " ", 
      RowBox[{"First", " ", "@", " ", 
       RowBox[{"StringCases", "[", 
        RowBox[{"source", ",", " ", "\n", "\t\t", 
         RowBox[{
          RowBox[{"Shortest", "[", 
           
           RowBox[{"\"\<MArgument_set\>\"", " ", "~~", " ", "$type__", " ", "~~",
             " ", "\"\<(\>\""}], "]"}], " ", ":>", " ", "\n", "\t\t\t", 
          "$type"}]}], "\n", "\t", "]"}]}]}], ";", "\n", "\t", "\n", "\t", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"name", ",", " ", "args", ",", " ", "resultType"}], "}"}], " ",
       "=", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"name", ",", " ", 
         RowBox[{
          RowBox[{"SortBy", "[", 
           RowBox[{"args", ",", " ", "Last"}], "]"}], "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", " ", 
            RowBox[{"1", " ", ";;", " ", "2"}]}], "]"}], "]"}], ",", " ", 
         "resultType"}], "}"}], " ", "//.", " ", "\n", "\t", 
       RowBox[{"{", "\n", "\t\t", 
        RowBox[{
         RowBox[{"\"\<Integer\>\"", " ", "->", " ", "Integer"}], ",", " ", 
         "\n", "\t\t", 
         RowBox[{"\"\<MNumericArray\>\"", " ", "->", 
          " ", "\"\<ByteArray\>\""}], ",", " ", "\n", "\t\t", 
         RowBox[{"\"\<UTF8String\>\"", " ", "->", " ", "String"}]}], "\n", 
        "\t", "}"}]}]}], ";", " ", "\n", "\t", "\n", "\t", 
     RowBox[{"holdArgs", " ", "=", " ", 
      RowBox[{
       RowBox[{"Apply", "[", "Sequence", "]"}], " ", "@", " ", 
       RowBox[{
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{"ToExpression", "[", 
           RowBox[{"#", ",", " ", "StandardForm", ",", " ", "Hold"}], "]"}], 
          "&"}], "]"}], " ", "@", " ", 
        RowBox[{"args", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "2"}], "]"}], "]"}]}]}]}], ";", "\n", "\t", 
     RowBox[{"argTypes", " ", "=", " ", 
      RowBox[{"args", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}], ";", "\n", "\t", "\n",
      "\t", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Hold", "[", 
          RowBox[{"#1", "[", "##2", "]"}], "]"}], "&"}], "[", 
        RowBox[{
         RowBox[{"ToExpression", "[", "name", "]"}], ",", " ", "holdArgs"}], 
        "]"}], ")"}], " ", "//.", " ", 
      RowBox[{"{", "\n", "\t\t", 
       RowBox[{
        RowBox[{"Hold", "[", "$$var_Symbol", "]"}], " ", ":>", " ", 
        RowBox[{"Pattern", "[", 
         RowBox[{"$$var", ",", " ", 
          RowBox[{"Blank", "[", "]"}]}], "]"}]}], "\n", "\t", "}"}]}]}]}], 
   "\n", "]"}]}]], "Code",
