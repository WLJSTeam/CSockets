   3.977490393862523*^9, 3.977630187090762*^9, 3.9776331937052603`*^9},
 CellLabel->"Out[57]=",ExpressionUUID->"8dfbccad-3d3d-4f31-bb07-db6ebc866a9a"]
}, Open  ]],

