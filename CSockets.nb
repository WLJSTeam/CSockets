Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"selected", ",", " ", "client", ",", " ", 
     RowBox[{"sockets", " ", "=", " ", "sockets"}], ",", " ", "request"}], 
    "}"}], ",", " ", "\n", "\t", 
   RowBox[{"While", "[", 
    RowBox[{"True", ",", " ", "\n", "\t\t", 
     RowBox[{
      RowBox[{"selected", " ", "=", " ", 
       RowBox[{"socketsSelect", "[", 
        RowBox[{"sockets", ",", " ", "1", ",", " ", "10000000"}], "]"}]}], ";",
       " ", "\n", "\t\t", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "selected", "]"}], " ", ">", " ", "0"}], ",", 
        " ", "\n", "\t\t\t", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"MemberQ", "[", 
            RowBox[{"selected", ",", " ", "socket1"}], "]"}], ",", " ", "\n", 
           "\t\t\t\t", 
           RowBox[{
            RowBox[{"client", " ", "=", " ", 
             RowBox[{"socketAccept", "[", "socket1", "]"}]}], ";", "\n", 
            "\t\t\t\t", 
            RowBox[{"sockets", " ", "=", " ", 
             RowBox[{"DeleteDuplicates", "[", 
              RowBox[{"Append", "[", 
               RowBox[{"sockets", ",", " ", "client"}], "]"}], "]"}]}]}]}], 
          "\n", "\t\t\t", "]"}], ";", "\n", "\t\t\t", 
         RowBox[{"Table", "[", "\n", "\t\t\t\t", 
          RowBox[{
           RowBox[{
            RowBox[{"request", " ", "=", " ", 
             RowBox[{"socketRecv", "[", 
              RowBox[{"s", ",", " ", "buffer", ",", " ", "1024"}], "]"}]}], ";",
             "\n", "\t\t\t\t", 
            RowBox[{"socketSendString", "[", 
             RowBox[{"s", ",", " ", "response", ",", " ", 
              RowBox[{"StringLength", "[", "response", "]"}]}], "]"}]}], ",", 
           " ", "\n", "\t\t\t\t", 
           RowBox[{"{", 
            RowBox[{"s", ",", " ", 
             RowBox[{"DeleteCases", "[", 
              RowBox[{"sockets", ",", " ", "socket1"}], "]"}]}], "}"}]}], 
          "\n", "\t\t\t", "]"}]}]}], "\n", "\t\t", "]"}]}]}], "\n", "\t", 
    "]"}]}], "\n", "]"}]], "Code",
