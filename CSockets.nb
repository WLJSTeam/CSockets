Cell[BoxData["\<\"DLLEXPORT int createTask(WolframLibraryData libData, mint \
Argc, MArgument *Args, MArgument Res) {\\n    char *funcName = \
MArgument_getUTF8String(Args[0]); // func name\\n    void *args = (void \
*)MArgument_getInteger(Args[1]); // integer pointer\\n\\n    void *taskFunc = \
getFuncByName(funcName);\\n    TaskArgs taskArgs;\\n    taskArgs = \
malloc(sizeof(struct TaskArgs_st));\\n    taskArgs->libData = libData;\\n    \
taskArgs->args = taskArgs;\\n    mint taskId = \
libData->ioLibraryFunctions->createAsynchronousTaskWithThread(taskFunc, \
taskArgs);\\n    MArgument_setInteger(Res, taskId);\\n    return \
LIBRARY_NO_ERROR;\\n}\"\>"], "Output",
 CellChangeTimes->{
  3.975550121505888*^9, {3.975551002349141*^9, 3.9755510252252607`*^9}, 
   3.9766240633441963`*^9, {3.976631493469596*^9, 3.976631500625286*^9}, {
