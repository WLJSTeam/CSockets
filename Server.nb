 RowBox[{
  RowBox[{"socketListen", "[", 
   RowBox[{"server", ",", " ", "4096"}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"buffer", " ", "=", " ", 
   RowBox[{"socketBufferCreate", "[", "1024", "]"}]}], ";"}]}], "Code",
 CellChangeTimes->{{3.9823707356241055`*^9, 3.9823708018481426`*^9}, {
