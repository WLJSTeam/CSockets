Cell[CellGroupData[{

Cell["Loop", "Section",
 CellChangeTimes->{{3.9823904539204082`*^9, 
  3.98239045460837*^9}},ExpressionUUID->"4ef290b2-9d37-c940-bdf5-\
87f87ac2a315"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"sockets", " ", "=", " ", 
   RowBox[{"{", "server", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"While", "[", 
   RowBox[{"True", ",", " ", "\n", "\t", 
    RowBox[{
     RowBox[{"ready", " ", "=", " ", 
      RowBox[{"socketsSelect", "[", 
       RowBox[{"sockets", ",", " ", 
        RowBox[{"Length", "[", "sockets", "]"}], ",", " ", "10000000"}], 
       "]"}]}], ";", "\n", "\t", 
     RowBox[{"Table", "[", " ", "\n", "\t\t", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"s", " ", "==", " ", "server"}], ",", " ", "\n", "\t\t\t", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"sockets", ",", " ", 
           RowBox[{"socketAccept", "[", "s", "]"}]}], "]"}], ",", " ", "\n", 
         "\t\t\t", 
         RowBox[{
          RowBox[{"socketRecv", "[", 
           RowBox[{"s", ",", " ", "buffer", ",", " ", "1024"}], "]"}], ";", 
          "\n", "\t\t\t", 
          RowBox[{"socketSendString", "[", 
           RowBox[{"s", ",", " ", "\"\<hello\>\"", ",", " ", "5"}], "]"}]}]}],
         "\n", "\t\t", "]"}], ",", "\n", "\t\t", 
       RowBox[{"{", 
        RowBox[{"s", ",", " ", "ready"}], "}"}]}], "\n", "\t", "]"}], ";"}]}],
    "\n", "]"}], ";"}]}], "Code",
 CellChangeTimes->{{3.98239048314489*^9, 
  3.9823906197207775`*^9}},ExpressionUUID->"7c4074cf-464a-f84f-be91-\
